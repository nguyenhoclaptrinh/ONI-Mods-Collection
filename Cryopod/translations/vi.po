msgctxt "Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTATTEMPERATURE.NAME"
msgid "Energy Saving Mode"
msgstr "Chế độ tiết kiệm năng lượng"

msgctxt ""
"Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTATTEMPERATURE.TOOLTIP"
msgid "Fully cooled down, this buiding has entered energy saving mode."
msgstr ""
"Khi đã nguội hoàn toàn, tòa nhà này đã chuyển sang chế độ tiết kiệm năng "
"lượng."

msgctxt "Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTCRYODAMAGE.NAME"
msgid "Warning, Duplicant is thawing improperly"
msgstr "Cảnh báo, Bản sao đang rã đông không đúng cách"

msgctxt "Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTCRYODAMAGE.TOOLTIP"
msgid "When this duplicant thaws fully, it won't have a good time."
msgstr "Khi bản sao này tan băng hoàn toàn, nó sẽ không có thời gian vui vẻ."

msgctxt ""
"Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTHEALTHSTATUS.HEALTHGOOD"
msgid "The Duplicant is in a healthy condition"
msgstr "Người sao chép đang trong tình trạng khỏe mạnh"

msgctxt ""
"Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTHEALTHSTATUS.HEALTHGOODNAME"
msgid "Healthy"
msgstr "Khỏe mạnh"

msgctxt ""
"Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTHEALTHSTATUS.HEALTHINCAPACITATE"
msgid ""
"The Duplicant has suffered extreme amounts of cell damage and will die if "
"thawed"
msgstr "Người sao chép đã bị tổn thương tế bào cực độ và sẽ chết nếu tan băng"

msgctxt ""
"Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTHEALTHSTATUS.HEALTHINCAPACITATENAME"
msgid "Critical"
msgstr "Phê bình"

msgctxt ""
"Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTHEALTHSTATUS.HEALTHMAJORDAMAGE"
msgid "The Duplicant has suffered major damage due to malfunctions!"
msgstr "Bản sao đã bị thiệt hại lớn do trục trặc!"

msgctxt ""
"Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTHEALTHSTATUS.HEALTHMAJORDAMAGENAME"
msgid "Severe Wounds"
msgstr "vết thương nặng"

msgctxt ""
"Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTHEALTHSTATUS.HEALTHSOMEDAMAGE"
msgid "The Duplicant has suffered minor damage due to malfunctions."
msgstr "Bản sao đã bị hư hại nhẹ do trục trặc."

msgctxt ""
"Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTHEALTHSTATUS.HEALTHSOMEDAMAGENAME"
msgid "Light Wounds"
msgstr "Vết thương nhẹ"

msgctxt "Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTHEALTHSTATUS.NAME"
msgid "Cryogenic Healthyness: {DupeHealthState}"
msgstr "Sức khỏe đông lạnh: {DupeHealthState}"

msgctxt ""
"Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTHEALTHSTATUS.TOOLTIP"
msgid "{DupeHealthStateTooltip}"
msgstr "{DupeHealthStateTooltip}"

msgctxt ""
"Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTINTERNALTEMPERATURE.NAME"
msgid "The Dupe is at {InternalTemperature}."
msgstr "Bản Dupe đang ở mức {InternalTemperature}."

msgctxt ""
"Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTINTERNALTEMPERATURE.TOOLTIP"
msgid "Cryogenic process cools down the body for preservation."
msgstr "Quá trình đông lạnh làm mát cơ thể để bảo quản."

msgctxt "Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTNAMESTATUS.NAME"
msgid "Duplicant in cryogenic sleep: {DupeName}"
msgstr "Nhân bản trong giấc ngủ đông lạnh: {DupeName}"

msgctxt "Cryopod.STRINGS.BUILDING.STATUSITEMS.CRY_DUPLICANTNAMESTATUS.TOOLTIP"
msgid "{DupeName} takes a cool nap."
msgstr "{DupeName} có một giấc ngủ ngắn thoải mái."

msgctxt ""
"Cryopod.STRINGS.BUILDINGS.PREFABS.CRY_BUILDABLECRYOTANK.DEFROSTBUTTON"
msgid "Defrost stored Friend"
msgstr "Rã đông được lưu trữ Friend"

msgctxt ""
"Cryopod.STRINGS.BUILDINGS.PREFABS.CRY_BUILDABLECRYOTANK.DEFROSTBUTTONCANCEL"
msgid "Cancel Defrosting"
msgstr "Hủy rã đông"

msgctxt ""
"Cryopod.STRINGS.BUILDINGS.PREFABS.CRY_BUILDABLECRYOTANK.DEFROSTBUTTONTOOLTIP"
msgid "Unfreeze the duplicant stored here."
msgstr "Giải phóng bản sao được lưu trữ ở đây."

msgctxt "Cryopod.STRINGS.BUILDINGS.PREFABS.CRY_BUILDABLECRYOTANK.DESC"
msgid ""
"A design found in an ancient facility, your Duplicants have managed to "
"almost perfectly replicate it."
msgstr ""
"Một thiết kế được tìm thấy trong một cơ sở cổ xưa, Người sao chép của bạn đã"
" sao chép nó gần như hoàn hảo."

msgctxt "Cryopod.STRINGS.BUILDINGS.PREFABS.CRY_BUILDABLECRYOTANK.EFFECT"
msgid ""
"Can store 1 Duplicant.\n"
"\n"
"Heats up during freezing.\n"
"Cools down during thawing."
msgstr ""
"Có thể lưu trữ 1 bản sao.\n"
"\n"
"Nóng lên trong quá trình đóng băng.\n"
"Làm mát trong quá trình tan băng."

msgctxt ""
"Cryopod.STRINGS.BUILDINGS.PREFABS.CRY_BUILDABLECRYOTANK.INPUT_LOGIC_PORT"
msgid "Thaw Duplicant"
msgstr "Làm tan bản sao"

msgctxt ""
"Cryopod.STRINGS.BUILDINGS.PREFABS.CRY_BUILDABLECRYOTANK.INPUT_LOGIC_PORT_ACTIVE"
msgid ""
"<b><style=\"logic_on\">Green Signal</style></b>: Triggers the thawing "
"process."
msgstr ""
"<b><style=\"logic_on\">Tín hiệu xanh</style></b>: Kích hoạt quá trình rã "
"đông."

msgctxt ""
"Cryopod.STRINGS.BUILDINGS.PREFABS.CRY_BUILDABLECRYOTANK.INPUT_LOGIC_PORT_INACTIVE"
msgid "<b><style=\"logic_off\">Red Signal</style></b>: Does nothing"
msgstr "<b><style=\"logic_off\">Tín hiệu đỏ</style></b>: Không làm gì cả"

msgctxt "Cryopod.STRINGS.BUILDINGS.PREFABS.CRY_BUILDABLECRYOTANK.NAME"
msgid "<link=\"CRYBUILDABLECRYOTANK\">Cryotank 4000</link>"
msgstr "<link=\"CRYBUILDABLECRYOTANK\">Cryotank 4000</link>"

msgctxt "Cryopod.STRINGS.BUILDINGS.PREFABS.CRY_BUILDABLECRYOTANKLIQUID.DESC"
msgid ""
"A design found in an ancient facility, your Duplicants have managed to "
"almost perfectly replicate it."
msgstr ""
"Một thiết kế được tìm thấy trong một cơ sở cổ xưa, Người sao chép của bạn đã"
" sao chép nó gần như hoàn hảo."

msgctxt "Cryopod.STRINGS.BUILDINGS.PREFABS.CRY_BUILDABLECRYOTANKLIQUID.EFFECT"
msgid ""
"Can store 1 Duplicant.\n"
"\n"
"Heats up during freezing.\n"
"Cools down during thawing.\n"
"\n"
"Exchanges temperature with the liquid pumped through."
msgstr ""
"Có thể lưu trữ 1 bản sao.\n"
"\n"
"Nóng lên trong quá trình đóng băng.\n"
"Làm mát trong quá trình tan băng.\n"
"\n"
"Trao đổi nhiệt độ với chất lỏng được bơm qua."

msgctxt "Cryopod.STRINGS.BUILDINGS.PREFABS.CRY_BUILDABLECRYOTANKLIQUID.NAME"
msgid "<link=\"CRYBUILDABLECRYOTANKLIQUID\">Cryotank 5000</link>"
msgstr "<link=\"CRYBUILDABLECRYOTANKLIQUID\">Cryotank 5000</link>"

msgctxt "Cryopod.STRINGS.CRYOPODRESEARCHTYPE.NAME"
msgid "Cryopod Analysis"
msgstr "Phân tích đông lạnh"

msgctxt "Cryopod.STRINGS.CRYOPODRESEARCHTYPE.RECIPEDESC"
msgid "Analyzing gravitas cryopods yields new knowledge."
msgstr "Phân tích gravitas cryopod mang lại kiến ​​thức mới"

msgctxt "Cryopod.STRINGS.DISEASES.CRYOSICKNESS.DESCRIPTION"
msgid ""
"After a botched thawing process, this dupe will take time to feel normal "
"again."
msgstr ""
"Sau quá trình rã đông không thành công, bản dupe này sẽ mất thời gian để cảm"
" thấy bình thường trở lại."

msgctxt "Cryopod.STRINGS.DISEASES.CRYOSICKNESS.DESCRIPTIVE_SYMPTOMS"
msgid "A lot of cells got pierced by a non standard cryopod thawing."
msgstr ""
"Rất nhiều tế bào đã bị xuyên thủng bởi quá trình rã đông cryopod không đạt "
"tiêu chuẩn."

msgctxt "Cryopod.STRINGS.DISEASES.CRYOSICKNESS.NAME"
msgid "Cryo Sickness"
msgstr "bệnh lạnh"

msgctxt "Cryopod.STRINGS.DUPLICANTS.STATUSITEMS.FORCETHAWED.NAME"
msgid "<link=\"FORCETHAWED\">Cryo Sickness</link>"
msgstr "<link=\"FORCETHAWED\">Bệnh Khóc</link>"

msgctxt "Cryopod.STRINGS.DUPLICANTS.STATUSITEMS.FORCETHAWED.TOOLTIP"
msgid "Being forcefully thawed, this Duplicant does not have a good time."
msgstr "Bị buộc phải rã đông, bản sao này không có thời gian vui vẻ."

msgctxt "Cryopod.STRINGS.RESEARCH.TECHS.FROSTEDDUPERESEARCH.DESC"
msgid ""
"Unlocked by investigating ancient artifacts left behind.\n"
"Enables freezing your Duplicants in cryosleep."
msgstr ""
"Mở khóa bằng cách điều tra các hiện vật cổ xưa bị bỏ lại.\n"
"Cho phép đóng băng Bản sao của bạn trong chế độ ngủ đông."

msgctxt "Cryopod.STRINGS.RESEARCH.TECHS.FROSTEDDUPERESEARCH.NAME"
msgid "<link=\"FROSTEDDUPERESEARCH\">Cryogenics</link>"
msgstr "<link=\"FROSTEDDUPERESEARCH\">Chất làm lạnh</link>"
