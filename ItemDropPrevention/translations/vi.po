msgctxt ""
"ItemDropPrevention.STRINGS.IDP_MOD_CONFIG.PAUSE_MENU_OPEN_CONFIG_BUTTONTEXT"
msgid "Adjust GripNowIncluded Settings"
msgstr "Điều chỉnh cài đặt đi kèm GripNow"

msgctxt "ItemDropPrevention.STRINGS.IDP_MOD_CONFIG.SWEEP_DROPPED_ITEMS"
msgid "Schedule sweep task for dropped items."
msgstr "Lên lịch nhiệm vụ quét các vật phẩm bị rơi."

msgctxt ""
"ItemDropPrevention.STRINGS.IDP_MOD_CONFIG.SWEEP_DROPPED_ITEMS_TOOLTIP"
msgid ""
"Automatically issue a sweep task for items that were dropped before reaching"
" their destinations"
msgstr "Tự động đưa ra nhiệm vụ quét các vật phẩm bị rơi trước khi đến đích"

msgctxt "ItemDropPrevention.STRINGS.IDP_MOD_CONFIG.WRANGLE_DROPPED_CRITTERS"
msgid "Schedule wrangle task for dropped critters."
msgstr "Lên lịch nhiệm vụ sắp xếp cho những sinh vật bị rơi."

msgctxt ""
"ItemDropPrevention.STRINGS.IDP_MOD_CONFIG.WRANGLE_DROPPED_CRITTERS_TOOLTIP"
msgid ""
"Automatically issue a new wrangle task for a critter if it was dropped "
"before reaching its destination"
msgstr ""
"Tự động đưa ra nhiệm vụ sắp xếp mới cho sinh vật nếu nó bị rơi trước khi đến"
" đích"
