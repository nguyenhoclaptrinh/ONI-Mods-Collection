msgctxt ""
"PeterHan.AirlockDoor.AirlockDoorStrings.BUILDING.STATUSITEMS.AIRLOCKSTOREDCHARGE.NAME"
msgid "Charge Available: {0}/{1}"
msgstr "Có thể tính phí: {0}/{1}"

msgctxt ""
"PeterHan.AirlockDoor.AirlockDoorStrings.BUILDING.STATUSITEMS.AIRLOCKSTOREDCHARGE.TOOLTIP"
msgid ""
"This Airlock has <b>{0}</b> of stored <style=\"KKeyword\">Power</style>\n"
"\n"
"It consumes up to <style=\"consumed\">{2}</style> per use"
msgstr ""
"Ngăn khí này có <b>{0}</b> trong số <style=\"KKeyword\">Điện năng</style> được lưu trữ\n"
"\n"
"Nó tiêu thụ tới <style=\"consumed\">{2}</style> mỗi lần sử dụng"

msgctxt ""
"PeterHan.AirlockDoor.AirlockDoorStrings.BUILDINGS.PREFABS.PAIRLOCKDOOR.DESC"
msgid ""
"Sucking Duplicants that have nowhere to go into space through "
"<link=\"PRESSUREDOOR\">Mechanized Airlocks</link> is poor taste. Airlock "
"Doors now allow Duplicants safe passage without the loss of any of their "
"mysterious fluids."
msgstr ""
"Hút các bản sao không có nơi nào để đi vào không gian thông qua "
"<link=\"PRESSUREDOOR\">Khóa khí cơ giới</link> là một điều kém thẩm mỹ. Cửa "
"Ngăn khí hiện cho phép Người sao chép đi qua an toàn mà không làm mất bất kỳ"
" chất lỏng bí ẩn nào của họ."

msgctxt ""
"PeterHan.AirlockDoor.AirlockDoorStrings.BUILDINGS.PREFABS.PAIRLOCKDOOR.EFFECT"
msgid ""
"Blocks <link=\"ELEMENTSLIQUID\">Liquid</link> and <link=\"ELEMENTSGAS\">Gas</link> flow, even while Duplicants are passing.\n"
"\n"
"Will not allow passage when no <link=\"POWER\">Power</link> is available.\n"
"\n"
"<link=\"CRITTERS\">Critters</link> can never pass through this door."
msgstr ""
"Các khối <link=\"ELEMENTSLIQUID\">Chất lỏng</link> và <link=\"ELEMENTSGAS\">Chất khí</link> chảy, ngay cả khi Người sao chép đang đi qua.\n"
"\n"
"Sẽ không cho phép đi qua khi không có <link=\"Điện năng\">Điện năng</link>.\n"
"\n"
"<link=\"Sinh vật\">Sinh vật</link> không bao giờ có thể đi qua cánh cửa này."

msgctxt ""
"PeterHan.AirlockDoor.AirlockDoorStrings.BUILDINGS.PREFABS.PAIRLOCKDOOR.LOGIC_OPEN"
msgid "Unlock/Lock"
msgstr "Mở khóa/Khóa"

msgctxt ""
"PeterHan.AirlockDoor.AirlockDoorStrings.BUILDINGS.PREFABS.PAIRLOCKDOOR.LOGIC_OPEN_ACTIVE"
msgid "<b><style=\"logic_on\">Green Signal</style></b>: Unlock door"
msgstr "<b><style=\"logic_on\">Tín hiệu xanh</style></b>: Mở khóa cửa"

msgctxt ""
"PeterHan.AirlockDoor.AirlockDoorStrings.BUILDINGS.PREFABS.PAIRLOCKDOOR.LOGIC_OPEN_INACTIVE"
msgid "<b><style=\"logic_off\">Red Signal</style></b>: Lock door"
msgstr "<b><style=\"logic_off\">Tín hiệu đỏ</style></b>: Khóa cửa"

msgctxt ""
"PeterHan.AirlockDoor.AirlockDoorStrings.BUILDINGS.PREFABS.PAIRLOCKDOOR.NAME"
msgid "<link=\"PAIRLOCKDOOR\">Airlock Door</link>"
msgstr "<link=\"PAIRLOCKDOOR\">Cửa khóa khí</link>"
