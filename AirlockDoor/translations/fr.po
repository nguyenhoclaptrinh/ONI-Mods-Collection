"PeterHan.AirlockDoor.AirlockDoorStrings.BUILDINGS.PREFABS.PAIRLOCKDOOR."
"LOGIC_OPEN"
msgid "Unlock/Lock"
msgstr "Déverrouiller/verrouiller"

#. PeterHan.AirlockDoor.AirlockDoorStrings.BUILDINGS.PREFABS.PAIRLOCKDOOR.LOGIC_OPEN_ACTIVE
msgctxt ""
"PeterHan.AirlockDoor.AirlockDoorStrings.BUILDINGS.PREFABS.PAIRLOCKDOOR."
"LOGIC_OPEN_ACTIVE"
msgid "<b><style=\"logic_on\">Green Signal</style></b>: Unlock door"
msgstr ""
"<b><style=\"logic_on\">Signal vert</style></b> : Déverrouiller la porte"

#. PeterHan.AirlockDoor.AirlockDoorStrings.BUILDINGS.PREFABS.PAIRLOCKDOOR.LOGIC_OPEN_INACTIVE
msgctxt ""
"PeterHan.AirlockDoor.AirlockDoorStrings.BUILDINGS.PREFABS.PAIRLOCKDOOR."
"LOGIC_OPEN_INACTIVE"
msgid "<b><style=\"logic_off\">Red Signal</style></b>: Lock door"
msgstr ""
"<b><style=\"logic_off\">Signal rouge</style></b> : Verrouiller la porte"

#. PeterHan.AirlockDoor.AirlockDoorStrings.BUILDINGS.PREFABS.PAIRLOCKDOOR.NAME
