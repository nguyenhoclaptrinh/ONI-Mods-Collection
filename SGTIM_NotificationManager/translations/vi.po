msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.ALERTS.CATEGORY"
msgid "Alerts"
msgstr "Cảnh báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.ALERTS.MUTEREDALERT"
msgid "Mute Red Alert Sound"
msgstr "Tắt âm thanh cảnh báo màu đỏ"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.ALERTS.MUTEYELLOWALERT"
msgid "Mute Yellow Alert Sound"
msgstr "Tắt âm thanh cảnh báo màu vàng"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.ATTACK.CATEGORY"
msgid "Chiến đấu!-Thông báo"
msgstr "Chiến đấu!-Thông báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.BROKENMACHINE.CATEGORY"
msgid "Công trình hỏng-Thông báo"
msgstr "Công cụ hỏng-Thông báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.DUPLICANTDIED.CATEGORY"
msgid "Mấy thằng Đệ đã chết-Thông báo"
msgstr "Kẻ thù đã chết-Thông báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.ENTOMBED.CATEGORY"
msgid "Vùi lấp-Thông báo"
msgstr "Thông báo"

msgctxt "SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.FLEE.CATEGORY"
msgid "Bỏ chạy!-Thông báo"
msgstr "Bỏ chạy!-Thông báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.FOODROT.CATEGORY"
msgid "Thực phẩm bị phân hủy-Thông báo"
msgstr "Thực tế sản phẩm bị hủy bỏ-Thông báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.INCAPACITATED.CATEGORY"
msgid "Ngất xỉu-Thông báo"
msgstr "Ngụ ý thông báo"

msgctxt "SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.MUTE_PING"
msgid "Mute notification ping"
msgstr "Tắt tiếng ping thông báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.MUTE_PING_TOOLTIP"
msgid "Enable this option to remove the ping-sound from the warning."
msgstr "Bật tùy chọn này để loại bỏ âm thanh ping khỏi cảnh báo."

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.PAUSE_ON_NOTIFICATION"
msgid "Pause game on trigger"
msgstr "Tạm dừng trò chơi khi kích hoạt"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.PAUSE_ON_NOTIFICATION_TOOLTIP"
msgid "Pauses the game when the notification triggers."
msgstr "Tạm dừng trò chơi khi thông báo kích hoạt."

msgctxt "SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.PEE.CATEGORY"
msgid "Đái dầm-Thông báo"
msgstr "Đái-Thông báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.PLANTDEATH.CATEGORY"
msgid "Cây đã chết-Thông báo"
msgstr "Cây đã chết-Thông báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.RADIATIONVOMITING.CATEGORY"
msgid "Nôn mửa do bức xạ-Thông báo"
msgstr "Nôn nao làm bức xạ-Thông báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.SCALDING.CATEGORY"
msgid "Bỏng-Thông báo"
msgstr "Bỏ qua thông báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.STARVATION.CATEGORY"
msgid "Đói-Thông báo"
msgstr "Đói-Thông báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.STARVATION.THRESHOLD"
msgid "Starvation Calorie Threshold"
msgstr "Ngưỡng calo khi đói"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.STARVATION.THRESHOLD_TOOLTIP"
msgid ""
"Calorie threshold for the starvation notification.\n"
"Default is 1000"
msgstr ""
"Ngưỡng calo cho thông báo đói.\n"
"Mặc định là 1000"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.STRESS.CATEGORY"
msgid "Stress cao-Thông báo"
msgstr "Căng thẳng cao-Thông báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.STRESS.THRESHOLD"
msgid "Stress Threshold"
msgstr "Ngưỡng căng thẳng"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.STRESS.THRESHOLD_TOOLTIP"
msgid ""
"Stress level where the notification triggers in percent.\n"
"Default is 80%"
msgstr ""
"Mức độ căng thẳng nơi thông báo kích hoạt tính bằng phần trăm.\n"
"Mặc định là 80%"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.SUFFOCATION.CATEGORY"
msgid "Ngạt thở-Thông báo"
msgstr "Thông báo văn bản"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.SUFFOCATION.THRESHOLD"
msgid "Suffocation Time Threshold"
msgstr "Ngưỡng thời gian ngạt thở"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.SUFFOCATION.THRESHOLD_TOOLTIP"
msgid ""
"Time from notification start to death by suffocation in seconds.\n"
"Default is 50 seconds, higher values warn earlier"
msgstr ""
"Thời gian từ khi nhận được thông báo đến khi chết do ngạt thở tính bằng giây.\n"
"Mặc định là 50 giây, giá trị cao hơn sẽ cảnh báo sớm hơn"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.UNREFRIGERATEDFOOD.CATEGORY"
msgid "Thức ăn chưa bảo quản-Thông báo"
msgstr "ăn chưa bảo quản-Thông báo"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.ZOOM_ON_NOTIFICATION"
msgid "Pan to origin"
msgstr "Xoay về nguồn gốc"

msgctxt ""
"SGTIM_NotificationManager.STRINGS.NOTIFICATION_CONFIG.ZOOM_ON_NOTIFICATION_TOOLTIP"
msgid "Moves the camera to the origin of the notification when it triggers."
msgstr "Di chuyển camera tới nơi xuất hiện thông báo khi nó kích hoạt."
