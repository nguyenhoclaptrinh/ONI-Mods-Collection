msgstr "Chỉ nhắm mục tiêu <style=\"KKeyword\">Dọn dẹp</style> việc vặt"

msgctxt ""
"ChainErrand.Strings.MYSTRINGS.UI.TOOLS.FILTERLAYERS.EMPTYPIPE.TOOLTIP"
msgid "Target <style=\"KKeyword\">Empty Pipe</style> errands only"
msgstr "Mục tiêu <style=\"KKeyword\">Ống rỗng</style> chỉ làm việc vặt"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.TOOLS.FILTERLAYERS.MOVETO.TOOLTIP"
msgid "Target <style=\"KKeyword\">Move To</style> errands only"
msgstr "Mục tiêu <style=\"KKeyword\">Chỉ di chuyển đến</style> việc vặt"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.TOOLTIPS.CHAINBUTTON"
msgid "Chain up errands to be executed in some specific order {Hotkey}"
msgstr ""
"Sắp xếp các công việc lặt vặt để thực hiện theo một số thứ tự cụ thể "
"{Hotkey}"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.TITLE"
msgid "Chain Tools"
msgstr "Công cụ dây chuyền"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.CREATEBUTTON"
msgid "Create"
msgstr "Tạo nên"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.DELETEBUTTON"
msgid "Delete"
msgstr "Xóa bỏ"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.CREATECHAIN"
msgid "Create Chain"
msgstr "Tạo chuỗi"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.CREATECHAIN_TOOLTIP"
msgid "Create the first link of a new chain"
msgstr "Tạo liên kết đầu tiên của chuỗi mới"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.CREATELINK"
msgid "Create/Expand Link"
msgstr "Tạo/Mở rộng liên kết"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.CREATELINK_TOOLTIP"
msgid ""
"Create a new link at the end/inside of an existing chain, or expand an "
"existing link"
msgstr ""
"Tạo một liên kết mới ở cuối/bên trong chuỗi hiện có hoặc mở rộng liên kết "
"hiện có"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.CHAINNUMBER"
msgid "Chain ID:"
msgstr "ID chuỗi:"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.CHAINNUMBER_TOOLTIP"
msgid "ID of the chain that should be modified"
msgstr "ID của chuỗi cần được sửa đổi"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.LINKNUMBER"
msgid "Link Nr.:"
msgstr "Liên kết số:"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.LINKNUMBER_TOOLTIP"
msgid ""
"Number of the link\n"
"If the number is whole, an existing link will be expanded\n"
"If the number is a fraction, a new link will be inserted inbetween"
msgstr ""
"Số liên kết\n"
"Nếu là số nguyên thì liên kết hiện có sẽ được mở rộng\n"
"Nếu số là phân số thì một liên kết mới sẽ được chèn vào giữa"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.GOTOLINK_TOOLTIP"
msgid "Go to this chain link"
msgstr "Tới liên kết chuỗi này"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.CHAINNUMBER_NOTFOUND"
msgid "NO CHAINS"
msgstr "KHÔNG CÓ CHUỖI"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.LINKNUMBER_NOTFOUND"
msgid "NO LINKS"
msgstr "KHÔNG CÓ LIÊN KẾT"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.DELETECHAIN"
msgid "Delete Chain"
msgstr "Xóa chuỗi"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.DELETECHAIN_TOOLTIP"
msgid "Delete an entire chain"
msgstr "Xóa toàn bộ chuỗi"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.DELETELINK"
msgid "Delete Errand"
msgstr "Xóa việc vặt"

msgctxt "ChainErrand.Strings.MYSTRINGS.UI.CHAINTOOLSMENU.DELETELINK_TOOLTIP"
msgid "Delete selected errands from the chain they are in"
msgstr "Xóa các công việc vặt đã chọn khỏi chuỗi chứa chúng"

