msgctxt ""
"PeterHan.SmartPumps.SmartPumpsStrings.BUILDINGS.PREFABS.FILTEREDGASPUMP.DESC"
msgid ""
"Rumors hold that hidden behind the parts from discarded Carbon Skimmers used"
" in this pump is a demon with a pair of chopsticks, picking gas molecules "
"from the air forever and ever."
msgstr ""
"Có tin đồn rằng ẩn đằng sau các bộ phận của Carbon Skimmer bỏ đi được sử "
"dụng trong máy bơm này là một con quỷ với một đôi đũa, vĩnh viễn nhặt các "
"phân tử khí từ không khí."

msgctxt ""
"PeterHan.SmartPumps.SmartPumpsStrings.BUILDINGS.PREFABS.FILTEREDGASPUMP.EFFECT"
msgid ""
"Draws in only the specified <link=\"ELEMENTSGAS\">Gas</link> and runs it through <link=\"GASPIPING\">Pipes</link>.\n"
"\n"
"Must be immersed in <link=\"ELEMENTSGAS\">Gas</link>."
msgstr ""
"Chỉ rút <link=\"ELEMENTSGAS\">Chất khí</link> được chỉ định và chạy qua <link=\"GASPIPING\">Pipes</link>.\n"
"\n"
"Phải đắm mình trong <link=\"ELEMENTSGAS\">Chất khí</link>."

msgctxt ""
"PeterHan.SmartPumps.SmartPumpsStrings.BUILDINGS.PREFABS.FILTEREDGASPUMP.NAME"
msgid "<link=\"FILTEREDGASPUMP\">Filtered Gas Pump</link>"
msgstr "<link=\"FILTEREDGASPUMP\">Bơm khí lọc</link>"

msgctxt ""
"PeterHan.SmartPumps.SmartPumpsStrings.BUILDINGS.PREFABS.FILTEREDLIQUIDPUMP.DESC"
msgid ""
"Scarred by nightmares of mixed liquid pools, an obsessive colony AI "
"commissioned this pump with an attached Element Sensor in an attempt to "
"purge this heresy forever."
msgstr ""
"Bị ám ảnh bởi những cơn ác mộng về các bể chứa chất lỏng hỗn hợp, một AI "
"thuộc địa đầy ám ảnh đã đặt cho chiếc máy bơm này một Bộ cảm biến phần tử "
"kèm theo nhằm nỗ lực thanh trừng tà giáo này mãi mãi."

msgctxt ""
"PeterHan.SmartPumps.SmartPumpsStrings.BUILDINGS.PREFABS.FILTEREDLIQUIDPUMP.EFFECT"
msgid ""
"Draws in only the specified <link=\"ELEMENTSLIQUID\">Liquid</link> and runs it through <link=\"LIQUIDPIPING\">Pipes</link>.\n"
"\n"
"Must be submerged in <link=\"ELEMENTSLIQUID\">Liquid</link>."
msgstr ""
"Chỉ rút <link=\"ELEMENTSLIQUID\">Chất lỏng</link> được chỉ định và chạy qua <link=\"LIQUIDPIPING\">Pipes</link>.\n"
"\n"
"Phải chìm trong <link=\"ELEMENTSLIQUID\">Chất lỏng</link>."

msgctxt ""
"PeterHan.SmartPumps.SmartPumpsStrings.BUILDINGS.PREFABS.FILTEREDLIQUIDPUMP.NAME"
msgid "<link=\"FILTEREDLIQUIDPUMP\">Filtered Liquid Pump</link>"
msgstr "<link=\"FILTEREDLIQUIDPUMP\">Bơm chất lỏng đã lọc</link>"

msgctxt "PeterHan.SmartPumps.SmartPumpsStrings.NOGASTOPUMP_DESC"
msgid ""
"This pump must be immersed in the proper <style=\"KKeyword\">Gas</style> to "
"work"
msgstr ""
"Máy bơm này phải được ngâm trong <style=\"KKeyword\">Chất khí</style> thích "
"hợp để hoạt động"

msgctxt "PeterHan.SmartPumps.SmartPumpsStrings.NOGASTOPUMP_NAME"
msgid "No Configured Gas to Pump"
msgstr "Không có khí được cấu hình để bơm"

msgctxt "PeterHan.SmartPumps.SmartPumpsStrings.NOLIQUIDTOPUMP_DESC"
msgid ""
"This pump must be immersed in the proper <style=\"KKeyword\">Liquid</style> "
"to work"
msgstr ""
"Máy bơm này phải được ngâm trong <style=\"KKeyword\">Chất lỏng</style> thích"
" hợp để hoạt động"

msgctxt "PeterHan.SmartPumps.SmartPumpsStrings.NOLIQUIDTOPUMP_NAME"
msgid "No Configured Liquid to Pump"
msgstr "Không có chất lỏng được cấu hình để bơm"

msgctxt ""
"PeterHan.SmartPumps.SmartPumpsStrings.BUILDINGS.PREFABS.VACUUMPUMP.DESC"
msgid ""
"After watching a Gas Pump work all night to lower the pressure in a room "
"from 5 mg to 4 mg, Liam decided to invent this Vacuum Pump instead of "
"wasting his time on the Manual Generator all day."
msgstr ""
"Sau khi xem Máy bơm xăng hoạt động suốt đêm để giảm áp suất trong phòng từ 5"
" mg xuống 4 mg, Liam quyết định phát minh ra Máy bơm chân không này thay vì "
"lãng phí thời gian cho Máy phát điện thủ công cả ngày."

msgctxt ""
"PeterHan.SmartPumps.SmartPumpsStrings.BUILDINGS.PREFABS.VACUUMPUMP.EFFECT"
msgid ""
"Draws in low-pressure <link=\"ELEMENTSGAS\">Gas</link> and runs it through <link=\"GASPIPING\">Pipes</link>.\n"
"\n"
"Must be immersed in <link=\"ELEMENTSGAS\">Gas</link>."
msgstr ""
"Hút vào <link=\"ELEMENTSGAS\">Chất khí</link> áp suất thấp và chạy qua <link=\"GASPIPING\">Ống</link>.\n"
"\n"
"Phải đắm mình trong <link=\"ELEMENTSGAS\">Chất khí</link>."

msgctxt ""
"PeterHan.SmartPumps.SmartPumpsStrings.BUILDINGS.PREFABS.VACUUMPUMP.NAME"
msgid "<link=\"VACUUMPUMP\">Vacuum Pump</link>"
msgstr "<link=\"VACUUMPUMP\">Bơm chân không</link>"
