msgctxt ""
"PeterHan.ThermalTooltips.ThermalTooltipsStrings.UI.THERMALTOOLTIPS.AND_JOIN"
msgid "[{0}] and "
msgstr "[{0}] và"

msgctxt ""
"PeterHan.ThermalTooltips.ThermalTooltipsStrings.UI.THERMALTOOLTIPS.BUILDING_CONDUCTIVITY"
msgid ""
"The completed {0} will have a thermal conductivity of <b>{1}</b>\n"
"\n"
"For every 1 {3} of difference between the building's <link=\"HEAT\">Temperature</link> and its surroundings, {2:##0.#} {4} will be transferred"
msgstr ""
"{0} đã hoàn thành sẽ có độ dẫn nhiệt <b>{1}</b>\n"
"\n"
"Với mỗi 1 {3} chênh lệch giữa <link=\"HEAT\">Nhiệt độ</link> của tòa nhà và khu vực xung quanh, {2:##0.#} {4} sẽ được chuyển"

msgctxt ""
"PeterHan.ThermalTooltips.ThermalTooltipsStrings.UI.THERMALTOOLTIPS.BUILDING_MELT_TEMPERATURE"
msgid "The completed {0} will melt at <b>{1}</b> into {2}"
msgstr "{0} đã hoàn thành sẽ tan chảy ở <b>{1}</b> thành {2}"

msgctxt ""
"PeterHan.ThermalTooltips.ThermalTooltipsStrings.UI.THERMALTOOLTIPS.BUILDING_THERMAL_MASS"
msgid ""
"The completed {0} will have a thermal mass of <b>{1:##0.#} {2}/{3}</b>\n"
"\n"
"Adding or removing {1:##0.#} {2} will change the building's <link=\"HEAT\">Temperature</link> by 1 {3}"
msgstr ""
"{0} đã hoàn thành sẽ có khối lượng nhiệt <b>{1:##0.#} {2}/{3}</b>\n"
"\n"
"Việc thêm hoặc xóa {1:##0.#} {2} sẽ thay đổi <link=\"HEAT\">Nhiệt độ</link> của tòa nhà thêm 1 {3}"

