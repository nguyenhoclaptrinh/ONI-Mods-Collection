msgctxt "ClusterTraitGenerationManager.STRINGS.CLUSTER_NAMES.CGM.DESCRIPTION"
msgid "This cluster has been handcrafted in the Cluster Generation Manager"
msgstr "Cụm này đã được tạo thủ công trong Trình quản lý tạo cụm"

msgctxt "ClusterTraitGenerationManager.STRINGS.CLUSTER_NAMES.CGM.NAME"
msgid "CGM Custom Cluster"
msgstr "Cụm tùy chỉnh CGM"

msgctxt "ClusterTraitGenerationManager.STRINGS.ERRORMESSAGES.MISSINGWORLD"
msgid ""
"Missing Worlds!\n"
"The preset cannot be loaded since its start world is missing."
msgstr ""
"Thế giới bị thiếu!\n"
"Không thể tải cài đặt trước vì thế giới bắt đầu của nó bị thiếu."

msgctxt ""
"ClusterTraitGenerationManager.STRINGS.ERRORMESSAGES.MISSINGWORLDS_TEXT"
msgid ""
"There were {0} worlds in the preset that\n"
"don't exist in the current game!"
msgstr ""
"Đã có {0} thế giới được cài đặt sẵn\n"
"không tồn tại trong trò chơi hiện tại!"

msgctxt ""
"ClusterTraitGenerationManager.STRINGS.ERRORMESSAGES.MISSINGWORLDS_TITLE"
msgid "Missing Worlds!"
msgstr "Thế giới bị thiếu!"

msgctxt ""
"ClusterTraitGenerationManager.STRINGS.ERRORMESSAGES.PLANETPLACEMENTERROR"
msgid ""
"Starmap Generation Error!\n"
"{0} could not be placed on the star map. Increase the maximum distance of of this asteroid to fix this issue."
msgstr ""
"Lỗi tạo bản đồ sao!\n"
"{0} không thể được đặt trên bản đồ sao. Tăng khoảng cách tối đa của tiểu hành tinh này để khắc phục vấn đề này."

msgctxt ""
"ClusterTraitGenerationManager.STRINGS.MODCONFIG.CHALLENGEASTEROIDS.NAME"
msgid "Enable Challenge Asteroids"
msgstr "Kích hoạt thử thách tiểu hành tinh"

msgctxt ""
"ClusterTraitGenerationManager.STRINGS.MODCONFIG.CHALLENGEASTEROIDS.TOOLTIP"
msgid ""
"Generate more challenging start asteroids like superconductive and regolith "
"moonlet"
msgstr ""
"Tạo ra các tiểu hành tinh khởi đầu đầy thách thức hơn như mặt trăng siêu dẫn"
" và regolith"

msgctxt ""
"ClusterTraitGenerationManager.STRINGS.MODCONFIG.MANUALCLUSTERPRESETS.NAME"
msgid "Automated Cluster Preset"
msgstr "Cài đặt trước cụm tự động"

msgctxt ""
"ClusterTraitGenerationManager.STRINGS.MODCONFIG.MANUALCLUSTERPRESETS.TOOLTIP"
msgid ""
"Each time you start a new CGM cluster, a cluster preset will be created automatically.\n"
"if deactivated, there will be a button for manual creation on the start screen instead."
msgstr ""
"Mỗi khi bạn bắt đầu một cụm CGM mới, một cài đặt trước của cụm sẽ được tạo tự động.\n"
"nếu tắt, thay vào đó sẽ có nút tạo thủ công trên màn hình bắt đầu."

msgctxt "ClusterTraitGenerationManager.STRINGS.UI.CATEGORYENUM.OUTER"
msgid "Outer Asteroids"
msgstr "Tiểu hành tinh bên ngoài"

msgctxt "ClusterTraitGenerationManager.STRINGS.UI.CATEGORYENUM.POI"
msgid "Points of Interest"
msgstr "Điểm ưa thích"

