msgctxt "ClusterTraitGenerationManager.STRINGS.UI.SEEDLOCK.NAME"
msgid "Seed rerolling affects traits"
msgstr "Việc cuộn lại hạt ảnh hưởng đến tính trạng"

msgctxt "ClusterTraitGenerationManager.STRINGS.UI.SEEDLOCK.NAME_MIXING"
msgid "reroll Mixings:"
msgstr "cuộn lại Hỗn hợp:"

msgctxt "ClusterTraitGenerationManager.STRINGS.UI.SEEDLOCK.NAME_SHORT"
msgid "reroll Traits:"
msgstr "cuộn lại"

