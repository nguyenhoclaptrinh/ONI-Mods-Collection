msgctxt ""
"PeterHan.MooReproduction.MooReproductionStrings.CREATURES.SPECIES.MOO.BABY.DESC"
msgid ""
"A cute little Gassy Moolet.\n"
"\n"
"One day it will grow into an adult <link=\"MOO\">Gassy Moo</link>."
msgstr ""
"Một bé Gassy Moolet dễ thương.\n"
"\n"
"Một ngày nào đó nó sẽ trưởng thành <link=\"MOO\">Gassy Moo</link>."

msgctxt ""
"PeterHan.MooReproduction.MooReproductionStrings.CREATURES.SPECIES.MOO.BABY.NAME"
msgid "<link=\"MOO\">Gassy Moolet</link>"
msgstr "<link=\"MOO\">Molet Gassy</link>"

msgctxt ""
"PeterHan.MooReproduction.MooReproductionStrings.CREATURES.STATUSITEMS.GIVINGBIRTH.NAME"
msgid "Giving Birth"
msgstr "Sinh con"

msgctxt ""
"PeterHan.MooReproduction.MooReproductionStrings.CREATURES.STATUSITEMS.GIVINGBIRTH.TOOLTIP"
msgid "Here it comes!"
msgstr "Nó tới đây!"

msgctxt ""
"PeterHan.MooReproduction.MooReproductionStrings.UI.FRONTEND.MOOREPRODUCTION.DISABLE_METEORS"
msgid "Disable Moo Meteors"
msgstr "Vô hiệu hóa thiên thạch Moo"

msgctxt ""
"PeterHan.MooReproduction.MooReproductionStrings.UI.TOOLTIPS.MOOREPRODUCTION.DISABLE_METEORS"
msgid ""
"Disables Moo Meteors from falling on any planetoid. Can help avoid an "
"exponential build-up of Gassy Moos."
msgstr ""
"Vô hiệu hóa các thiên thạch Moo rơi xuống bất kỳ hành tinh nào. Có thể giúp "
"tránh sự tích tụ Gassy Moos theo cấp số nhân."
