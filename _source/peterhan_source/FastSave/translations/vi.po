# Messages
msgctxt "PeterHan.FastSave.FastSaveStrings.AUTOSAVE_FAILED"
msgid "Autosave failed!"
msgstr "Tự động lưu không thành công!"

msgctxt "PeterHan.FastSave.FastSaveStrings.AUTOSAVE_PROGRESS"
msgid "Auto-Save in progress"
msgstr "Đang tự động lưu dưới nền"

msgctxt "PeterHan.FastSave.FastSaveStrings.DESKTOP_QUIT_WARNING"
msgid "Exit to Desktop may corrupt the current autosave!"
msgstr "Thoát ra Desktop có thể làm hỏng quá trình lưu tự động hiện tại!"

msgctxt "PeterHan.FastSave.FastSaveStrings.IO_ERROR"
msgid "IOException. You may not have enough free space!"
msgstr "IOException. Bạn có thể không có đủ không gian trống!"

# Options
msgctxt "PeterHan.FastSave.FastSaveOptions.BackgroundSave.title"
msgid "Background Save"
msgstr "Lưu Dưới Nền"

msgctxt "PeterHan.FastSave.FastSaveOptions.BackgroundSave.tooltip"
msgid "Performs autosaves in the background, allowing\r\ngame play to continue while saving"
msgstr "Thực hiện tự động lưu dưới nền, cho phép tiếp tục chơi game trong khi lưu"

msgctxt "PeterHan.FastSave.FastSaveOptions.Mode.title"
msgid "Save Optimization"
msgstr "Tối Ưu Hóa Lưu Game"

msgctxt "PeterHan.FastSave.FastSaveOptions.Mode.tooltip"
msgid "Trades off impact to colony statistics with save / load time"
msgstr "Đánh đổi dữ liệu thống kê thuộc địa lấy tốc độ lưu/tải game nhanh hơn"

msgctxt "PeterHan.FastSave.FastSaveOptions.DelegateSave.title"
msgid "Use Delegates"
msgstr "Sử Dụng Delegate"

msgctxt "PeterHan.FastSave.FastSaveOptions.DelegateSave.tooltip"
msgid "Reduces time consuming reflection during saves to reduce total time to save"
msgstr "Giảm thiểu reflection tốn thời gian khi lưu để giảm tổng thời gian lưu game"

msgctxt "PeterHan.FastSave.FastSaveOptions.DisableTimelapse.title"
msgid "Disable Daily Timelapse"
msgstr "Tắt Daily Timelapse"

msgctxt "PeterHan.FastSave.FastSaveOptions.DisableTimelapse.tooltip"
msgid "Disables taking screenshots at the end of each cycle to speed up saving"
msgstr "Tắt chụp ảnh daily timelapse ở cuối mỗi chu kỳ để tăng tốc độ lưu game"

msgctxt "PeterHan.FastSave.FastSaveOptions.DisableColonyPreview.title"
msgid "Disable Colony Preview"
msgstr "Tắt Colony Preview"

msgctxt "PeterHan.FastSave.FastSaveOptions.DisableColonyPreview.tooltip"
msgid "Disables colony preview screenshots during saving to speed up saving"
msgstr "Tắt chụp ảnh xem trước thuộc địa khi lưu để tăng tốc độ lưu game"
