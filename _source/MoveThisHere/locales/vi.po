msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_BOTTLE_OFF"
msgid "Disable Auto-Bottle"
msgstr "Tắt nhận đồ đóng chai"

msgctxt ""
"MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_BOTTLE_OFF_TOOLTIP"
msgid ""
"If disabled, Duplicants will no longer deliver bottled liquids/gases to this"
" hauling point."
msgstr "Nếu tắt, Duplicant sẽ không mang chất lỏng hoặc chất khí đóng chai tới điểm vận chuyển này nữa."

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_BOTTLE_ON"
msgid "Enable Auto-Bottle"
msgstr "Bật nhận đồ đóng chai"

msgctxt ""
"MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_BOTTLE_ON_TOOLTIP"
msgid ""
"If enabled, Duplicants will deliver bottled liquids/gases to this hauling "
"point."
msgstr "Nếu bật, Duplicant sẽ mang chất lỏng hoặc chất khí đóng chai tới điểm vận chuyển này."

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_DROP_OFF"
msgid "Disable Auto-Deconstruct"
msgstr "Tắt tự động tháo dỡ"

msgctxt ""
"MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_DROP_OFF_TOOLTIP"
msgid "Cancel automatic deconstructing when full"
msgstr "Hủy tự động tháo dỡ khi điểm vận chuyển đầy"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_DROP_ON"
msgid "Enable Auto-Deconstruct"
msgstr "Bật tự động tháo dỡ"

msgctxt ""
"MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_DROP_ON_TOOLTIP"
msgid ""
"If enabled, automatically deconstruct hauling point and drop items when storage "
"is full"
msgstr "Nếu bật, tự động tháo dỡ điểm vận chuyển này và thả toàn bộ vật phẩm ra đất khi kho chứa đầy"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_SPILL_OFF"
msgid "Disable Auto-Spill"
msgstr "Tắt tự động xả"

msgctxt ""
"MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_SPILL_OFF_TOOLTIP"
msgid "Drop bottles of liquids and gasses rather than spilling into the world"
msgstr "Giữ nguyên chất lỏng và chất khí dưới dạng chai/canister thay vì xả trực tiếp ra môi trường"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_SPILL_ON"
msgid "Enable Auto-Spill"
msgstr "Bật tự động xả"

msgctxt ""
"MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_SPILL_ON_TOOLTIP"
msgid ""
"If enabled, automatically spill liquids and gasses instead of dropping "
"bottles when hauling point is removed"
msgstr "Nếu bật, tự động xả trực tiếp chất lỏng và chất khí ra môi trường thay vì giữ dưới dạng chai khi xóa điểm vận chuyển này"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.REMOVE"
msgid "Remove"
msgstr "Xóa bỏ"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.REMOVE_TOOLTIP"
msgid "Remove this hauling point and drop all items here"
msgstr "Xóa bỏ điểm vận chuyển này và thả toàn bộ vật phẩm trong kho chứa ra đất"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.PREFABS.HAULINGPOINT.DESC"
msgid ""
"Relocate selected items here, then deconstruct to drop them on the ground."
msgstr "Vận chuyển các vật phẩm được chọn tới điểm này, sau đó tháo dỡ để thả chúng trực tiếp xuống đất."

msgctxt "MoveThisHere.STRINGS.BUILDINGS.PREFABS.HAULINGPOINT.EFFECT"
msgid "A temporary designation to bring items to a specific place."
msgstr "Một điểm đánh dấu tạm thời giúp gom các vật phẩm chỉ định đến vị trí này."

msgctxt "MoveThisHere.STRINGS.BUILDINGS.PREFABS.HAULINGPOINT.NAME"
msgid "<link=\"HAULINGPOINT\">Hauling Point</link>"
msgstr "<link=\"HAULINGPOINT\">Điểm vận chuyển</link>"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_EJECT_ON"
msgid "Enable Auto-Eject"
msgstr "Bật tự động xả đồ"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_EJECT_ON_TOOLTIP"
msgid "If enabled, automatically drop all items on the ground and keep hauling point when storage is full"
msgstr "Nếu bật, tự động xả toàn bộ vật phẩm ra đất khi đầy nhưng vẫn giữ lại điểm vận chuyển"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_EJECT_OFF"
msgid "Disable Auto-Eject"
msgstr "Tắt tự động xả đồ"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.AUTO_EJECT_OFF_TOOLTIP"
msgid "Cancel automatic ejecting when full"
msgstr "Không tự động xả vật phẩm khi đầy"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.MANUAL_EJECT"
msgid "Eject Contents"
msgstr "Xả đồ ngay"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.MANUAL_EJECT_TOOLTIP"
msgid "Drop all stored items onto the ground immediately without deconstructing the Hauling Point"
msgstr "Xả toàn bộ vật phẩm đang chứa ra sàn ngay lập tức mà không tháo dỡ điểm vận chuyển"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.ALLOW_ITEM_REMOVAL_ON"
msgid "Allow Retrieve (Dupes/Sweepers)"
msgstr "Cho phép thu hồi (Đệ/Sweeper)"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.ALLOW_ITEM_REMOVAL_ON_TOOLTIP"
msgid "Allow Duplicants and Auto-Sweepers to retrieve items from this hauling point. Warning: May cause transport loops if filter is active!"
msgstr "Cho phép Duplicant và Auto-Sweeper lấy đồ ra khỏi điểm vận chuyển này. Cảnh báo: Có thể gây ra vòng lặp vận chuyển nếu bộ lọc đang hoạt động!"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.ALLOW_ITEM_REMOVAL_OFF"
msgid "Disallow Retrieve (Dupes/Sweepers)"
msgstr "Cấm thu hồi (Đệ/Sweeper)"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.ALLOW_ITEM_REMOVAL_OFF_TOOLTIP"
msgid "Lock all items inside this hauling point. Duplicants and Auto-Sweepers will not be able to retrieve them."
msgstr "Khóa toàn bộ đồ bên trong điểm vận chuyển này. Duplicant và Auto-Sweeper sẽ không thể lấy đồ ra."

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.STATUS_AUTO_EJECT"
msgid "Auto-Eject on full"
msgstr "Tự động xả khi đầy"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.STATUS_AUTO_DECONSTRUCT"
msgid "Auto-Deconstruct on full"
msgstr "Tự động tháo dỡ khi đầy"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.STATUS_RETRIEVAL"
msgid "Retrieval by Dupes/Sweepers"
msgstr "Thu hồi (Đệ/Sweeper)"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.ENABLED"
msgid "Enabled"
msgstr "Bật"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.DISABLED"
msgid "Disabled"
msgstr "Tắt"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.ALLOWED"
msgid "Allowed"
msgstr "Được phép"

msgctxt "MoveThisHere.STRINGS.BUILDINGS.BUTTONS.HAULINGPOINT.DISALLOWED"
msgid "Disallowed"
msgstr "Bị cấm"
