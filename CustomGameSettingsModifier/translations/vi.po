msgctxt ""
"CustomGameSettingsModifier.STRINGS.UI.CUSTOMGAMESETTINGSCHANGER.BUTTONTEXT"
msgid "Change Difficulty Settings"
msgstr "Thay đổi cài đặt độ khó"

msgctxt ""
"CustomGameSettingsModifier.STRINGS.UI.CUSTOMGAMESETTINGSCHANGER.CHANGEWARNING"
msgid "<color=#fec315>Most of these changes require a reload!</color>"
msgstr ""
"<color=#fec315>Hầu hết những thay đổi này đều yêu cầu tải lại!</color>"

msgctxt ""
"CustomGameSettingsModifier.STRINGS.UI.CUSTOMGAMESETTINGSCHANGER.CHANGEWARNINGTOOLTIP"
msgid ""
"Changing the majority of these settings wont have an immediate effect.\n"
"To activate the effects:\n"
"1. Change settings to your desired configuration.\n"
"2. Save the game.\n"
"3. Load that save game.\n"
"4. Your changes should now be active."
msgstr ""
"Việc thay đổi phần lớn các cài đặt này sẽ không có tác dụng ngay lập tức.\n"
"Để kích hoạt các hiệu ứng:\n"
"1. Thay đổi cài đặt thành cấu hình mong muốn của bạn.\n"
"2. Lưu trò chơi.\n"
"3. Tải game save đó.\n"
"4. Bây giờ những thay đổi của bạn sẽ có hiệu lực."

msgctxt ""
"CustomGameSettingsModifier.STRINGS.UI.CUSTOMGAMESETTINGSCHANGER.CLOSE.TEXT"
msgid "Close"
msgstr "Đóng"

msgctxt ""
"CustomGameSettingsModifier.STRINGS.UI.CUSTOMGAMESETTINGSCHANGER.TITLE.TITLETEXT"
msgid "Difficulty Settings"
msgstr "Cài đặt độ khó"
