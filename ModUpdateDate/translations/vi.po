msgstr "<b>{0}</b>: <color=#FF0000>{1}</color>"

msgctxt ""
"PeterHan.ModUpdateDate.ModUpdateDateStrings.UI.MODUPDATER.UPDATE_FOOTER_CONFIG"
msgid ""
"\n"
"<b><color=#FFCC00>Back up any valuable mod configurations now manually!</color></b>"
msgstr ""
"<b><color=#FFCC00>Sao lưu thủ công mọi cấu hình mod có giá trị ngay bây "
"giờ!</color></b>"

msgctxt ""
"PeterHan.ModUpdateDate.ModUpdateDateStrings.UI.MODUPDATER.UPDATE_FOOTER_ERROR"
msgid ""
"\n"
"Check your connection, and that the mods directory has sufficient disk space and permissions."
msgstr ""
"Kiểm tra kết nối của bạn và đảm bảo thư mục mod có đủ dung lượng ổ đĩa và "
"quyền."

msgctxt ""
"PeterHan.ModUpdateDate.ModUpdateDateStrings.UI.MODUPDATER.UPDATE_FOOTER_OK"
msgid ""
"\n"
"{0} will be updated on the next restart."
msgstr "{0} sẽ được cập nhật vào lần khởi động lại tiếp theo."

