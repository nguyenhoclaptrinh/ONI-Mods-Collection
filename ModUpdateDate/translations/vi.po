msgstr "Không tìm thấy tập tin để tải về"

msgctxt ""
"PeterHan.ModUpdateDate.ModUpdateDateStrings.UI.MODUPDATER.UPDATE_OFFLINE"
msgid "Cannot download in Offline Mode"
msgstr "Không thể tải xuống ở Chế độ ngoại tuyến"

