msgstr "{0} đã được phát hiện"

msgctxt ""
"SetStartDupes.STRINGS.UI.CAREPACKAGEEDITOR.UNLOCKCONDITIONTOOLTIPS.OR"
msgid "OR"
msgstr "HOẶC"

msgctxt ""
"SetStartDupes.STRINGS.UI.CAREPACKAGEEDITOR.UNLOCKCONDITIONTOOLTIPS.START"
msgid "This care package unlocks after:"
msgstr "Gói chăm sóc này sẽ mở khóa sau:"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.ADDANDREMOVE.NAME"
msgid "Add/Remove Interests and Traits"
msgstr "Thêm/Xóa sở thích và đặc điểm"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.ADDANDREMOVE.TOOLTIP"
msgid ""
"Allows to add new or remove existing Traits and Interests on Duplicants.\n"
"Can be overpowered if used excessively."
msgstr ""
"Cho phép thêm mới hoặc xóa các Đặc điểm và Sở thích hiện có đối với Người trùng lặp.\n"
"Có thể bị áp đảo nếu sử dụng quá mức."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.ADDVACCILATORTRAITS.NAME"
msgid "Allow adding Vaccilator Traits"
msgstr "Cho phép thêm Đặc điểm Vaccilator"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.ADDVACCILATORTRAITS.TOOLTIP"
msgid "Allows adding Neural-Vaccilator-Traits with the \"Add Trait\" Feature."
msgstr ""
"Cho phép thêm Đặc điểm thần kinh-Vaccilator với tính năng \"Thêm đặc điểm\"."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGEEDITOR.NAME"
msgid "Open Care Package Editor"
msgstr "Trình chỉnh sửa gói chăm sóc mở"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGEEDITOR.TOOLTIP"
msgid ""
"View and modify the different additional care packages or create new ones."
msgstr "Xem và sửa đổi các gói chăm sóc bổ sung khác nhau hoặc tạo gói mới."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGEMULTIPLIER.NAME"
msgid "Care Package Multiplier"
msgstr "Hệ số gói chăm sóc"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGEMULTIPLIER.TOOLTIP"
msgid ""
"Global multiplier for the amount of item amount inside of care packages.\n"
"Default is 1."
msgstr ""
"Hệ số nhân toàn cầu cho số lượng vật phẩm bên trong các gói chăm sóc.\n"
"Mặc định là 1."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLY.BEDCOUNT.NAME"
msgid "Bed Count"
msgstr "Số giường"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLY.BEDCOUNT.TOOLTIP"
msgid ""
"When the number of duplicants in your colony reaches the number of "
"constructed beds, the printing pod will only print care packages."
msgstr ""
"Khi số lượng bản sao trong thuộc địa của bạn đạt đến số lượng giường được "
"xây dựng, bộ phận in sẽ chỉ in các gói chăm sóc."

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLY.BEDCOUNT_SIC.NAME"
msgid "Bed Count (Sharing is Caring)"
msgstr "Đếm Giường (Sẻ chia là quan tâm)"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLY.BEDCOUNT_SIC.TOOLTIP"
msgid ""
"Use this option when you use the mod \"Sharing is Caring\".\n"
"If the mod is not enabled, this option works like the regular \"Bed Count\" option.\n"
"When the number of duplicants in your colony reaches the number of constructed beds times the number of schedules, the printing pod will only print care packages.\n"
"As an example; if you have 3 beds, with 4 schedules, the printing pod will stop offering duplicants once there are 12 (3x4)."
msgstr ""
"Sử dụng tùy chọn này khi bạn sử dụng mod \"Chia sẻ là quan tâm\".\n"
"Nếu mod không được bật, tùy chọn này hoạt động giống như tùy chọn \"Đếm giường\" thông thường.\n"
"Khi số lượng bản sao trong thuộc địa của bạn đạt đến số lượng giường được xây dựng nhân với số lượng lịch trình, bộ phận in sẽ chỉ in các gói chăm sóc.\n"
"Như một ví dụ; nếu bạn có 3 giường, với 4 lịch trình, bộ phận in sẽ ngừng cung cấp bản sao khi có 12 giường (3x4)."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLY.DUPECOUNT.NAME"
msgid "Duplicant Count"
msgstr "Số lượng trùng lặp"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLY.DUPECOUNT.TOOLTIP"
msgid ""
"When the number of duplicants in your colony is at or above the configured "
"threshold, the printing pod will only print care packages."
msgstr ""
"Khi số lượng bản sao trong thuộc địa của bạn bằng hoặc cao hơn ngưỡng được "
"định cấu hình, nhóm in sẽ chỉ in các gói chăm sóc."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLY.NAME"
msgid "Print Care Packages only"
msgstr "Chỉ các gói chăm sóc in"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLY.NONE.NAME"
msgid "Disabled"
msgstr "Tàn tật"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLY.NONE.TOOLTIP"
msgid "The printing pod will print duplicants and care packages as normal."
msgstr "Bộ phận in sẽ in các bản sao và gói bảo trì như bình thường."

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLY.PRINTERCHECKBOX.NAME"
msgid "Toggle on Printer"
msgstr "Bật máy in"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLY.PRINTERCHECKBOX.TOOLTIP"
msgid ""
"When the (new) checkbox in the sidescreen of the printing pod is checked, it"
" will only print care packages."
msgstr ""
"Khi hộp kiểm (mới) trong màn hình bên của hộp in được chọn, nó sẽ chỉ in các"
" gói chăm sóc."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLY.TOOLTIP"
msgid ""
"When enabled, the printing pod will only give care packages when the configured condition has been satisfied\n"
"Overrides the care package configuration of a save game (no care package difficulty setting is ignored)."
msgstr ""
"Khi được bật, nhóm in sẽ chỉ cung cấp các gói chăm sóc khi đáp ứng được điều kiện đã định cấu hình\n"
"Ghi đè cấu hình gói chăm sóc của trò chơi đã lưu (không bỏ qua cài đặt độ khó của gói chăm sóc)."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLYDUPECAP.NAME"
msgid "Duplicant Threshold for care packages only"
msgstr "Ngưỡng trùng lặp chỉ dành cho các gói chăm sóc"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLYDUPECAP.TOOLTIP"
msgid ""
"Only has an effect if \"Print Care Packages only\" is enabled and configured to use the option \"Duplicant Count\".\n"
"While above or at this number of duplicants, the printer will only give care packages."
msgstr ""
"Chỉ có hiệu lực nếu \"Chỉ gói chăm sóc in\" được bật và định cấu hình để sử dụng tùy chọn \"Số lượng bản sao\".\n"
"Khi ở trên hoặc ở số lượng bản sao này, nhà in sẽ chỉ đưa ra các gói chăm sóc."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLYPACKAGECAP.NAME"
msgid "Number of care packages for care packages only"
msgstr "Số gói chăm sóc chỉ dành cho gói chăm sóc"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.CAREPACKAGESONLYPACKAGECAP.TOOLTIP"
msgid ""
"Only has an effect if \"Print Care Packages only\" is enabled.\n"
"Set the number of care packages that generate when the cap is in effect."
msgstr ""
"Chỉ có hiệu lực nếu \"Chỉ gói chăm sóc in\" được bật.\n"
"Đặt số lượng gói chăm sóc được tạo khi giới hạn có hiệu lực."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CATEGORIES.A_GAMESTART"
msgid "Options for Game Start"
msgstr "Tùy chọn bắt đầu trò chơi"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CATEGORIES.B_PRINTINGPOD"
msgid "Options for Printing Pod"
msgstr "Tùy chọn cho hộp in"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CATEGORIES.C_EXTRAS"
msgid "Options for Traits and Interests"
msgstr "Tùy chọn về Đặc điểm và Sở thích"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CATEGORIES.D_SKINSETTINGS"
msgid "Skin Options"
msgstr "Tùy chọn da"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.CATEGORIES.E_UTIL"
msgid "Extra Settings"
msgstr "Cài đặt bổ sung"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.DIRECTATTRIBUTEEDITING.NAME"
msgid "Direct Attribute Editing"
msgstr "Chỉnh sửa thuộc tính trực tiếp"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.DIRECTATTRIBUTEEDITING.TOOLTIP"
msgid ""
"Allows to directly edit the starting attributes of duplicants.\n"
"Can be overpowered."
msgstr ""
"Cho phép chỉnh sửa trực tiếp các thuộc tính bắt đầu của bản sao.\n"
"Có thể bị áp đảo."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.DUPLICANTSTARTAMOUNT.NAME"
msgid "Number of Starting Duplicants"
msgstr "Số lượng bản sao bắt đầu"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.DUPLICANTSTARTAMOUNT.TOOLTIP"
msgid "Choose the amount of duplicants you want to start with."
msgstr "Chọn số lượng bản sao bạn muốn bắt đầu."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.FORCEPRINTINGMODEL.NAME"
msgid "Print only specific duplicant models"
msgstr "Chỉ in các mẫu trùng lặp cụ thể"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.FORCEPRINTINGMODEL.TOOLTIP"
msgid ""
"Force the printing pod to only produce duplicants of the selected model"
msgstr "Buộc nhóm in chỉ tạo các bản sao của mẫu đã chọn"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.HERMITSKIN.NAME"
msgid "Hermit Skin"
msgstr "Da ẩn sĩ"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.HERMITSKIN.TOOLTIP"
msgid ""
"Adds the Hermit to the pool of selectable skins\n"
"once the story trait has been completed atleast once on any savegame."
msgstr ""
"Thêm Hermit vào nhóm giao diện có thể lựa chọn\n"
"khi đặc điểm câu chuyện đã được hoàn thành ít nhất một lần trên bất kỳ trò chơi lưu trữ nào."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.INTERESTPOINTSBALANCING.NAME"
msgid "Interest Point Balancing"
msgstr "Cân bằng điểm lãi"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.INTERESTPOINTSBALANCING.TOOLTIP"
msgid ""
"Use the vanilla interest point bonus for active interests determined by active traits.\n"
"Deactivate to override this point limit."
msgstr ""
"Sử dụng phần thưởng điểm lãi suất vanilla cho các sở thích hoạt động được xác định bởi các đặc điểm hoạt động.\n"
"Vô hiệu hóa để ghi đè giới hạn điểm này."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.LIVEDUPESKINCHANGE.NAME"
msgid "Skins for active Duplicants"
msgstr "Giao diện cho người sao chép đang hoạt động"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.LIVEDUPESKINCHANGE.TOOLTIP"
msgid "Change the Skin of already existing duplicants"
msgstr "Thay đổi giao diện của các bản sao hiện có"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.LIVEDUPESTATCHANGE.NAME"
msgid "Enable Duplicity-style Duplicant Editor"
msgstr "Kích hoạt trình soạn thảo trùng lặp kiểu trùng lặp"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.LIVEDUPESTATCHANGE.TOOLTIP"
msgid ""
"Edit your active duplicants in a new editor similar to the Duplicity-"
"savegame editor"
msgstr ""
"Chỉnh sửa các bản sao đang hoạt động của bạn trong trình chỉnh sửa mới tương"
" tự như trình chỉnh sửa trò chơi lưu trùng lặp"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.MODIFYDURINGGAME_CAREPACKAGES.NAME"
msgid "Care Package selection menu"
msgstr "Menu lựa chọn Gói Chăm sóc"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.MODIFYDURINGGAME_CAREPACKAGES.TOOLTIP"
msgid ""
"Enable this option allows replacing printing pod care packages from a list of all at that time unlocked care packages.\n"
"Enable Sandbox or Debug to ignore the unlock condition and make ALL packages available to select, regardless of unlock status."
msgstr ""
"Bật tùy chọn này cho phép thay thế các gói chăm sóc in từ danh sách tất cả các gói chăm sóc đã được mở khóa tại thời điểm đó.\n"
"Bật Hộp cát hoặc Gỡ lỗi để bỏ qua điều kiện mở khóa và cung cấp TẤT CẢ các gói để chọn, bất kể trạng thái mở khóa."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.MODIFYDURINGGAME_MINIONS.NAME"
msgid "Modification of printing pod Duplicants"
msgstr "Sửa đổi nhóm in"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.MODIFYDURINGGAME_MINIONS.TOOLTIP"
msgid ""
"Enable this option to add the modify button to printing pod dupes\n"
"When disabled, the feature only appears on the starter dupe selection.\n"
"This also enables the use of presets."
msgstr ""
"Bật tùy chọn này để thêm nút sửa đổi để in bản sao nhóm\n"
"Khi bị tắt, tính năng này chỉ xuất hiện trên lựa chọn bản dupe khởi động.\n"
"Điều này cũng cho phép sử dụng các cài đặt trước."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.MORECAREPACKAGES.NAME"
msgid "Enable Care Package Editor"
msgstr "Bật Trình chỉnh sửa gói chăm sóc"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.MORECAREPACKAGES.TOOLTIP"
msgid ""
"Additional types of care packages become available to print.\n"
"These can be viewed and modified in the care package editor.\n"
"By default it contains a small selection of items that can potentially become unavailable.\n"
"Also allows disabling of vanilla care packages."
msgstr ""
"Các loại gói chăm sóc bổ sung có sẵn để in.\n"
"Bạn có thể xem và sửa đổi những thông tin này trong trình chỉnh sửa gói chăm sóc.\n"
"Theo mặc định, nó chứa một số lựa chọn nhỏ các mục có khả năng không còn khả dụng.\n"
"Cũng cho phép vô hiệu hóa các gói chăm sóc vanilla."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.MYSTERIOUSMINIONMODE.NAME"
msgid "Mysterious Minion Mode"
msgstr "Chế độ Minion bí ẩn"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.MYSTERIOUSMINIONMODE.TOOLTIP"
msgid "All Interests and Traits are hidden until printed"
msgstr "Tất cả Sở thích và Đặc điểm đều bị ẩn cho đến khi được in"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.NEWGAMEPLUS.NAME"
msgid "NewGame+"
msgstr "Trò chơi mới+"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.NEWGAMEPLUS.TOOLTIP"
msgid ""
"Start your game with dupes you sent through the tear in previous "
"playthroughs."
msgstr ""
"Bắt đầu trò chơi của bạn với những trò lừa đảo mà bạn đã gửi qua nước mắt "
"trong các lần chơi trước."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.NOJOYREACTION.NAME"
msgid "Disable Overjoyed Responses"
msgstr "Vô hiệu hóa các phản hồi quá vui mừng"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.NOJOYREACTION.TOOLTIP"
msgid "Deactivates Overjoyed Responses on newly generated duplicants"
msgstr "Vô hiệu hóa Phản hồi vui mừng trên các bản sao mới được tạo"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.NORMALTRAITSONBIONICS.NAME"
msgid "Allow normal traits on Bionic Duplicants"
msgstr "Cho phép các đặc điểm bình thường trên Bản sao Bionic"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.NORMALTRAITSONBIONICS.TOOLTIP"
msgid "When active, allows adding regular traits to bionic duplicants."
msgstr ""
"Khi hoạt động, cho phép thêm các đặc điểm thông thường vào các bản sao sinh "
"học."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.NOSTRESSREACTION.NAME"
msgid "Disable Stress Reactions"
msgstr "Vô hiệu hóa phản ứng căng thẳng"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.NOSTRESSREACTION.TOOLTIP"
msgid "Deactivates Stress Reactions on newly generated duplicants"
msgstr "Vô hiệu hóa các phản ứng căng thẳng trên các bản sao mới được tạo"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.OVERRIDEPRINTERCAREPACKAGECOUNT.NAME"
msgid "Override printing pod care package count"
msgstr "Ghi đè số lượng gói chăm sóc nhóm in"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.OVERRIDEPRINTERCAREPACKAGECOUNT.TOOLTIP"
msgid ""
"Override the number of care packages offered in the printing pod.\n"
"A value of 0 or lower disables this feature.\n"
"Disabling care packages in the difficulty settings disables this feature.\n"
"No effect if care packages only mode is active."
msgstr ""
"Ghi đè số lượng gói chăm sóc được cung cấp trong nhóm in.\n"
"Giá trị 0 hoặc thấp hơn sẽ vô hiệu hóa tính năng này.\n"
"Việc tắt các gói chăm sóc trong cài đặt độ khó sẽ tắt tính năng này.\n"
"Không có hiệu lực nếu chế độ chỉ gói chăm sóc được kích hoạt."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.OVERRIDEPRINTERDUPECOUNT.NAME"
msgid "Override printing pod dupe count"
msgstr "Ghi đè số lượng bản sao của nhóm in"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.OVERRIDEPRINTERDUPECOUNT.TOOLTIP"
msgid ""
"Override the number of duplicants offered in the printing pod.\n"
"A value of 0 or lower disables this feature."
msgstr ""
"Ghi đè số lượng bản sao được cung cấp trong nhóm in.\n"
"Giá trị 0 hoặc thấp hơn sẽ vô hiệu hóa tính năng này."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.PAUSEONREADYTOPRING.NAME"
msgid "Pause on \"ready to print\""
msgstr "Tạm dừng ở trạng thái \"sẵn sàng in\""

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.PAUSEONREADYTOPRING.TOOLTIP"
msgid "Pause the game when the printing pod has recharged for a new print"
msgstr "Tạm dừng trò chơi khi hộp in đã được sạc lại để in mới"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.PODDUPESKINCHANGE.NAME"
msgid "Skin selection for Printing Pod Duplicants"
msgstr "Lựa chọn giao diện cho Bản sao Pod in"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.PODDUPESKINCHANGE.TOOLTIP"
msgid "Change the Skin of printing pod duplicants"
msgstr "Thay đổi giao diện của bản sao pod in"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.PRINTINGPODRECHARGETIME.NAME"
msgid "Printing pod cooldown time"
msgstr "Thời gian hồi chiêu của hộp in"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.PRINTINGPODRECHARGETIME.TOOLTIP"
msgid ""
"Time it takes for the printing pod to recharge for the next print in cycles.\n"
"Default is 3 cycles."
msgstr ""
"Thời gian cần thiết để hộp in nạp lại năng lượng cho lần in tiếp theo theo chu kỳ.\n"
"Mặc định là 3 chu kỳ."

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.PRINTINGPODRECHARGETIMEFIRST.NAME"
msgid "First print time"
msgstr "Lần in đầu tiên"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.PRINTINGPODRECHARGETIMEFIRST.TOOLTIP"
msgid ""
"Time after the printing pod offers its first print, in cycles.\n"
"Default is 2.5 cycles."
msgstr ""
"Thời gian sau khi nhóm in đưa ra bản in đầu tiên, tính theo chu kỳ.\n"
"Mặc định là 2,5 chu kỳ."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.REROLLCRYOPODANDJORGE.NAME"
msgid "Hermit/Cryopod Modification"
msgstr "Sửa đổi Hermit/Cryopod"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.REROLLCRYOPODANDJORGE.TOOLTIP"
msgid ""
"Allows modifying of the Hermit and Cryopod Duplicants.\n"
"\"Ancient Knowledge\"-Trait no longer takes the slot of a positive trait during generation of these duplicants."
msgstr ""
"Cho phép sửa đổi Bản sao Hermit và Cryopod.\n"
"\"Kiến thức cổ xưa\" -Đặc điểm không còn chiếm vị trí đặc điểm tích cực trong quá trình tạo ra các bản sao này."

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.REROLLDURINGGAME_CAREPACKAGES.NAME"
msgid "Reroll Care Packages"
msgstr "Gói chăm sóc lại"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.REROLLDURINGGAME_CAREPACKAGES.TOOLTIP"
msgid ""
"Enable this option to add the reroll button to printing pod care packages."
msgstr "Bật tùy chọn này để thêm nút cuộn lại để in các gói chăm sóc nhóm."

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.REROLLDURINGGAME_LIMITCOUNTER.NAME"
msgid "Limit Reroll Count"
msgstr "Giới hạn số lần cuộn lại"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.REROLLDURINGGAME_LIMITCOUNTER.TOOLTIP"
msgid ""
"Limit how many times you can reroll in tge printing pod each time the it becomes ready.\n"
"\n"
"Only has an effect if any of the printing pod reroll options are enabled\n"
"\n"
"A value of 0 disables any limiting.\n"
"\n"
"Does not affect direct editing options, play with those disabled if you want to avoid temptation."
msgstr ""
"Giới hạn số lần bạn có thể cuộn lại trong nhóm in tge mỗi khi nó sẵn sàng.\n"
"\n"
"Chỉ có hiệu lực nếu bất kỳ tùy chọn cuộn lại nhóm in nào được bật\n"
"\n"
"Giá trị 0 sẽ vô hiệu hóa mọi giới hạn.\n"
"\n"
"Không ảnh hưởng đến các tùy chọn chỉnh sửa trực tiếp, hãy chơi với những tùy chọn bị vô hiệu hóa nếu bạn muốn tránh bị cám dỗ."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.REROLLDURINGGAME_MINIONS.NAME"
msgid "Reroll printing pod duplicants"
msgstr "Reroll bản sao pod in"

msgctxt ""
"SetStartDupes.STRINGS.UI.DSS_OPTIONS.REROLLDURINGGAME_MINIONS.TOOLTIP"
msgid ""
"Enable this option to add the reroll button to printing pod Duplicants."
msgstr "Bật tùy chọn này để thêm nút cuộn lại vào nhóm in Bản sao."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.SKINSDOREACTS.NAME"
msgid "Skins include reactions"
msgstr "Da bao gồm các phản ứng"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.SKINSDOREACTS.TOOLTIP"
msgid ""
"When applying a skin, the inherited overjoyed response and stress reaction "
"get applied in addition to the skin."
msgstr ""
"Khi thoa lên da, phản ứng vui mừng và phản ứng căng thẳng được di truyền sẽ "
"được áp dụng cùng với da."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.SORTEDCAREPACKAGES.NAME"
msgid "Sorted Care Package Lists"
msgstr "Danh sách gói chăm sóc được sắp xếp"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.SORTEDCAREPACKAGES.TOOLTIP"
msgid ""
"Care packages listings are sorted alphabetically.\n"
"Affects care package editor and printing pod selection\n"
"Care packages in the editor can be sorted manually when this option is turned off."
msgstr ""
"Danh sách các gói chăm sóc được sắp xếp theo thứ tự bảng chữ cái.\n"
"Ảnh hưởng đến việc lựa chọn trình soạn thảo gói chăm sóc và nhóm in\n"
"Các gói chăm sóc trong trình chỉnh sửa có thể được sắp xếp theo cách thủ công khi tắt tùy chọn này."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.SORTEDPRINTINGPOD.NAME"
msgid "Sorted Printing Pod"
msgstr "Pod in được sắp xếp"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.SORTEDPRINTINGPOD.TOOLTIP"
msgid ""
"Printing pod entries are sorted by their type, dupes come first, then care "
"packages."
msgstr ""
"Các mục trong nhóm in được sắp xếp theo loại của chúng, các bản sao xuất "
"hiện trước, sau đó là các gói chăm sóc."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.STARTUPRESOURCES.NAME"
msgid "Extra Starting Resources"
msgstr "Tài nguyên khởi đầu bổ sung"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.STARTUPRESOURCES.TOOLTIP"
msgid ""
"Add some extra startup resources for your additional duplicants.\n"
"Only goes in effect with more than 3 dupes.\n"
"Only accounts for extra dupes above 3."
msgstr ""
"Thêm một số tài nguyên khởi động bổ sung cho các bản sao bổ sung của bạn.\n"
"Chỉ có hiệu lực với hơn 3 lần lừa đảo.\n"
"Chỉ chiếm các khoản lừa đảo bổ sung trên 3."

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.SUPPORTEDDAYS.NAME"
msgid "Supported Days"
msgstr "Ngày được hỗ trợ"

msgctxt "SetStartDupes.STRINGS.UI.DSS_OPTIONS.SUPPORTEDDAYS.TOOLTIP"
msgid ""
"Amount of days the extra starting resources should last.\n"
"No effect if \"Extra Starting Resources\" is disabled."
msgstr ""
"Số ngày mà tài nguyên ban đầu bổ sung sẽ kéo dài.\n"
"Không có hiệu lực nếu \"Tài nguyên khởi đầu bổ sung\" bị tắt."

msgctxt "SetStartDupes.STRINGS.UI.DUPEEDITING.CATEGORIES.HEADER.LABEL"
msgid "Duplicants"
msgstr "Bản sao"

msgctxt "SetStartDupes.STRINGS.UI.DUPEEDITING.CONFIRMATIONDIALOG.APPLYCHANGES"
msgid "Apply changes"
msgstr "Áp dụng thay đổi"

msgctxt "SetStartDupes.STRINGS.UI.DUPEEDITING.CONFIRMATIONDIALOG.CANCEL"
msgid "Cancel"
msgstr "Hủy bỏ"

msgctxt ""
"SetStartDupes.STRINGS.UI.DUPEEDITING.CONFIRMATIONDIALOG.DISCARDCHANGES"
msgid "Discard changes"
msgstr "Hủy thay đổi"

msgctxt "SetStartDupes.STRINGS.UI.DUPEEDITING.CONFIRMATIONDIALOG.TEXT"
msgid ""
"Warning, there are pending changes that have not been applied yet.\n"
"Choose an action on how to proceed:"
msgstr ""
"Cảnh báo, có những thay đổi đang chờ xử lý chưa được áp dụng.\n"
"Chọn một hành động về cách tiến hành:"

msgctxt "SetStartDupes.STRINGS.UI.DUPEEDITING.CONFIRMATIONDIALOG.TITLE"
msgid "Unsaved Changes"
msgstr "Những thay đổi chưa được lưu"

msgctxt ""
"SetStartDupes.STRINGS.UI.DUPEEDITING.DETAILS.CONTENT.SCROLLRECTCONTAINER.EFFECTS.DYNAMIC_EFFECT_TOOLTIP"
msgid ""
"This effect has been created dynamically by the game without registering as a resource.\n"
"Thus you won't be able to readd it from the list if you decide to remove it."
msgstr ""
"Hiệu ứng này đã được trò chơi tạo ra một cách linh hoạt mà không cần đăng ký làm tài nguyên.\n"
"Vì vậy, bạn sẽ không thể đọc lại nó từ danh sách nếu bạn quyết định xóa nó."

msgctxt ""
"SetStartDupes.STRINGS.UI.DUPEEDITING.DETAILS.CONTENT.SCROLLRECTCONTAINER.EFFECTS.EFFECT"
msgid "Effect"
msgstr "Tác dụng"

msgctxt ""
"SetStartDupes.STRINGS.UI.DUPEEDITING.DETAILS.CONTENT.SCROLLRECTCONTAINER.EFFECTS.TIMEREMAINING"
msgid "Remaining time in seconds | Remove Effect"
msgstr "Thời gian còn lại tính bằng giây | Xóa hiệu ứng"

msgctxt ""
"SetStartDupes.STRINGS.UI.DUPEEDITING.DETAILS.CONTENT.SCROLLRECTCONTAINER.NEWBUTTONPREFAB.LABEL"
msgid "Add new effect"
msgstr "Thêm hiệu ứng mới"

msgctxt ""
"SetStartDupes.STRINGS.UI.DUPEEDITING.DETAILS.CONTENT.SCROLLRECTCONTAINER.NEWBUTTONPREFAB.TOOLTIP"
msgid "Choose another effect to add to the duplicant"
msgstr "Chọn một hiệu ứng khác để thêm vào bản sao"

msgctxt ""
"SetStartDupes.STRINGS.UI.DUPEEDITING.DETAILS.CONTENT.SCROLLRECTCONTAINER.SKILLS.EXPERIENCE"
msgid "Experience:"
msgstr "Kinh nghiệm:"

msgctxt ""
"SetStartDupes.STRINGS.UI.DUPEEDITING.DETAILS.CONTENT.SCROLLRECTCONTAINER.SKILLS.MASTERY"
msgid "Mastered"
msgstr "Thành thạo"

msgctxt ""
"SetStartDupes.STRINGS.UI.DUPEEDITING.DETAILS.CONTENT.SCROLLRECTCONTAINER.SKILLS.SKILL"
msgid "Skill"
msgstr "Kỹ năng"

msgctxt ""
"SetStartDupes.STRINGS.UI.DUPEEDITING.DETAILS.CONTENT.SCROLLRECTCONTAINER.TRAITINTERESTCONTAINER.CONTENT.GRP2.ADDINTERESTBUTTON.TEXT"
msgid "Add new interest"
msgstr "Thêm sở thích mới"

msgctxt ""
"SetStartDupes.STRINGS.UI.DUPEEDITING.DETAILS.CONTENT.SCROLLRECTCONTAINER.TRAITINTERESTCONTAINER.CONTENT.GRP2.ADDINTERESTBUTTON.TOOLTIP"
msgid "Choose another interest to add to the duplicant"
msgstr "Chọn một sở thích khác để thêm vào bản sao"

msgctxt ""
"SetStartDupes.STRINGS.UI.DUPEEDITING.DETAILS.CONTENT.SCROLLRECTCONTAINER.TRAITINTERESTCONTAINER.CONTENT.GRP2.ADDTRAITBUTTON.TEXT"
msgid "Add new trait"
msgstr "Thêm đặc điểm mới"

msgctxt ""
"SetStartDupes.STRINGS.UI.DUPEEDITING.DETAILS.CONTENT.SCROLLRECTCONTAINER.TRAITINTERESTCONTAINER.CONTENT.GRP2.ADDTRAITBUTTON.TOOLTIP"
msgid "Choose another trait to add to the duplicant"
