msgctxt ""
"SetStartDupes.STRINGS.UI.CAREPACKAGEEDITOR.HORIZONTALLAYOUT.OBJECTLIST.SHOWVANILLA.TOOLTIP"
msgid ""
"Also show vanilla care packages in the list.\n"
"Note that these cannot be modified."
msgstr ""
"Đồng thời hiển thị các gói chăm sóc vanilla trong danh sách.\n"
"Lưu ý rằng những điều này không thể được sửa đổi."

msgctxt "SetStartDupes.STRINGS.UI.CAREPACKAGEEDITOR.RESETALLPACKAGES.TEXT"
msgid ""
"Are you sure you want to reset all modifications you have done to the care "
"package selection?"
msgstr ""
"Bạn có chắc chắn muốn đặt lại tất cả các sửa đổi bạn đã thực hiện đối với "
"việc lựa chọn gói chăm sóc không?"

msgctxt "SetStartDupes.STRINGS.UI.CAREPACKAGEEDITOR.RESETALLPACKAGES.TITLE"
msgid "Reset Care Packages"
msgstr "Đặt lại các gói chăm sóc"

msgctxt "SetStartDupes.STRINGS.UI.CAREPACKAGEEDITOR.TITLE"
msgid "Care Package Editor"
msgstr "Trình chỉnh sửa gói chăm sóc"

msgctxt "SetStartDupes.STRINGS.UI.CAREPACKAGEEDITOR.UNKNOWN_ITEM_TOOLTIP"
msgid ""
"The item of this care package could not be found in the current game "
"version."
msgstr ""
"Không thể tìm thấy vật phẩm của gói chăm sóc này trong phiên bản trò chơi "
"hiện tại."

msgctxt ""
"SetStartDupes.STRINGS.UI.CAREPACKAGEEDITOR.UNLOCKCONDITIONTOOLTIPS.ALWAYSAVAILABLE"
msgid "This care package is always unlocked"
msgstr "Gói chăm sóc này luôn được mở khóa"

