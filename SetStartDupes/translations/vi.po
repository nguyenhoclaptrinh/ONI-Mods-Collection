msgctxt ""
"SetStartDupes.STRINGS.UI.CAREPACKAGEEDITOR.HORIZONTALLAYOUT.OBJECTLIST.SCROLLAREA.CONTENT.PRESETENTRYPREFAB.TOGGLE_VANILLA_CAREPACKAGE"
msgid ""
"Toggle this vanilla care package from the care package list.\n"
"Disabled care packages won't show up in the selection list and cannot be rolled."
msgstr ""
"Chuyển đổi gói chăm sóc vanilla này khỏi danh sách gói chăm sóc.\n"
"Các gói chăm sóc người khuyết tật sẽ không hiển thị trong danh sách lựa chọn và không thể cuộn được."

msgctxt ""
"SetStartDupes.STRINGS.UI.CAREPACKAGEEDITOR.HORIZONTALLAYOUT.OBJECTLIST.SEARCHBAR.CLEARTOOLTIP"
