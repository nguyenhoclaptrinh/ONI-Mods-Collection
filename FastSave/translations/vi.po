msgstr "Thoát ra Desktop có thể làm hỏng quá trình lưu tự động hiện tại!"

msgctxt "PeterHan.FastSave.FastSaveStrings.IO_ERROR"
msgid "IOException. You may not have enough free space!"
msgstr "IOException. Bạn có thể không có đủ không gian trống!"
