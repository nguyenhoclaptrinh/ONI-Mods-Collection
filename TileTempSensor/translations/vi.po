msgctxt ""
"PeterHan.TileTempSensor.TileTempSensorStrings.BUILDINGS.PREFABS.TILETEMPSENSOR.DESC"
msgid ""
"Liquid drops have been sent an official eviction notice with the invention "
"of a Thermo Sensor that can transfer heat effectively with its surrounding "
"solid tiles."
msgstr ""
"Những giọt chất lỏng đã được gửi thông báo trục xuất chính thức với việc "
"phát minh ra Cảm biến nhiệt có thể truyền nhiệt hiệu quả với các viên gạch "
"đặc xung quanh."

msgctxt ""
"PeterHan.TileTempSensor.TileTempSensorStrings.BUILDINGS.PREFABS.TILETEMPSENSOR.EFFECT"
msgid ""
"Sends a <b><style=\"logic_on\">Green Signal</style></b> or a "
"<b><style=\"logic_off\">Red Signal</style></b> when ambient "
"<link=\"HEAT\">Temperature</link> enters the chosen range."
msgstr ""
"Gửi <b><style=\"logic_on\">Tín hiệu xanh</style></b> hoặc "
"<b><style=\"logic_off\">Tín hiệu đỏ</style></b> khi <link=\"HEAT\">Nhiệt "
"độ</link> của môi trường xung quanh đi vào phạm vi đã chọn."

msgctxt ""
"PeterHan.TileTempSensor.TileTempSensorStrings.BUILDINGS.PREFABS.TILETEMPSENSOR.NAME"
msgid "<link=\"TILETEMPSENSOR\">Thermo Sensor Tile</link>"
msgstr "<link=\"TILETEMPSENSOR\">Gạch cảm biến nhiệt</link>"
