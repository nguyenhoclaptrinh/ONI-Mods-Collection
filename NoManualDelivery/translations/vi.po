msgctxt "NoManualDelivery.STRINGS.AUTOMATABLE_TOOLTIP"
msgid "Allow only if the {SOLIDTRANSFERARM} can't do it in a certain time"
msgstr ""
"Chỉ cho phép nếu {SOLIDTRANSFERARM} không thể thực hiện được trong một thời "
"gian nhất định"

msgctxt "NoManualDelivery.STRINGS.MOD_DESCRIPTION"
msgid ""
"Adds a \"Allow Manual Use\" checkbox for very many buildings to efficiently "
"use the conveyor system and prevent duplicantes from manually delivering "
"resources to those buildings."
msgstr ""
"Thêm hộp kiểm \"Cho phép sử dụng thủ công\" cho rất nhiều tòa nhà để sử dụng"
" hiệu quả hệ thống băng tải và ngăn chặn những kẻ trùng lặp cung cấp tài "
"nguyên theo cách thủ công cho các tòa nhà đó."

msgctxt "NoManualDelivery.STRINGS.MOD_TITLE"
msgid "No Manual Delivery"
msgstr "Không giao hàng thủ công"

msgctxt "NoManualDelivery.STRINGS.OPTIONS.ALLOWALWAYSPICKUPEDIBLE.NAME"
msgid "Duplicants can always pick up Food and Medicine"
msgstr "Người sao chép luôn có thể nhặt Thực phẩm và Thuốc"

msgctxt "NoManualDelivery.STRINGS.OPTIONS.ALLOWALWAYSPICKUPEDIBLE.TOOLTIP"
msgid ""
"Duplicants will ignore the {ALLOWMANUALBUTTON} checkbox when picking up food"
" and medicine to eat it."
msgstr ""
"Người sao chép sẽ bỏ qua hộp kiểm {ALLOWMANUALBUTTON} khi nhặt thức ăn và "
"thuốc để ăn."

msgctxt "NoManualDelivery.STRINGS.OPTIONS.ALLOWALWAYSPICKUPKETTLE.NAME"
msgid "Duplicants can always pick up Water from {ICEKETTLE}"
msgstr "Người sao chép luôn có thể lấy Nước từ {ICEKETTLE}"

msgctxt "NoManualDelivery.STRINGS.OPTIONS.ALLOWALWAYSPICKUPKETTLE.TOOLTIP"
msgid ""
"Duplicants will ignore the {ALLOWMANUALBUTTON} checkbox when picking up "
"Water from {ICEKETTLE}."
msgstr ""
"Người sao chép sẽ bỏ qua hộp kiểm {ALLOWMANUALBUTTON} khi lấy Nước từ "
"{ICEKETTLE}."

msgctxt ""
"NoManualDelivery.STRINGS.OPTIONS.ALLOWTRANSFERARMPICKUPGASLIQUID.NAME"
msgid ""
"{SOLIDTRANSFERARM} can pick up and deliver liquid/gas Bottles and Canisters"
msgstr ""
"{SOLIDTRANSFERARM} có thể nhận và giao các chai và hộp đựng chất lỏng/khí"

msgctxt ""
"NoManualDelivery.STRINGS.OPTIONS.ALLOWTRANSFERARMPICKUPGASLIQUID.TOOLTIP"
msgid ""
"Also adds the {ALLOWMANUALBUTTON} checkbox to the Pitcher Pump, Canister "
"Filler, Bottle Emptier and Canister Emptier."
msgstr ""
"Đồng thời thêm hộp kiểm {ALLOWMANUALBUTTON} vào Máy bơm bình, Máy rót ống "
"đựng, Máy đổ chai và Máy đổ ống đựng."

msgctxt "NoManualDelivery.STRINGS.OPTIONS.BYDEFAULT.NAME"
msgid "Turn it on for newly built Buildings"
msgstr "Bật nó cho các tòa nhà mới được xây dựng"

msgctxt "NoManualDelivery.STRINGS.OPTIONS.CHORES.NAME"
msgid "Enable for Buildings"
msgstr "Bật cho tòa nhà"

msgctxt "NoManualDelivery.STRINGS.OPTIONS.CHORES.TOOLTIP"
msgid ""
"Additional the {ALLOWMANUALBUTTON} checkbox mode with ★.\n"
"Duplicants will deliver items only if the {SOLIDTRANSFERARM} can't do it in a certain time."
msgstr ""
"Bổ sung chế độ hộp kiểm {ALLOWMANUALBUTTON} bằng ★.\n"
"Người sao chép sẽ chỉ phân phối các mặt hàng nếu {SOLIDTRANSFERARM} không thể thực hiện việc đó trong một thời gian nhất định."

msgctxt "NoManualDelivery.STRINGS.OPTIONS.HOLDMODE.CATEGORY"
msgid "★ Intellectual mode"
msgstr "★ Chế độ trí tuệ"

msgctxt "NoManualDelivery.STRINGS.OPTIONS.ITEMS.NAME"
msgid "Enable for Items on the floor"
msgstr "Kích hoạt cho các vật phẩm trên sàn"

msgctxt "NoManualDelivery.STRINGS.OPTIONS.ITEMS.TOOLTIP"
msgid ""
"Duplicants will pick up Items on the floor only if the {SOLIDTRANSFERARM} "
"can't do it in a certain time."
msgstr ""
"Người sao chép sẽ chỉ nhặt Vật phẩm trên sàn nếu {SOLIDTRANSFERM} không thể "
"làm điều đó trong một thời gian nhất định."

msgctxt "NoManualDelivery.STRINGS.OPTIONS.TIMEOUT.NAME"
msgid "Timeout"
msgstr "Hết giờ"
