#. LightBridge.STRINGS.BUILDINGS.PREFABS.LB_LIGHTBRIDGEEMITTER.DESC
msgctxt "LightBridge.STRINGS.BUILDINGS.PREFABS.LB_LIGHTBRIDGEEMITTER.DESC"
msgid "Những cây cầu này được làm từ ánh sáng. Nếu bạn dụi má vào một bên, điều đó sẽ giống như bạn đang đứng bên ngoài với ánh nắng chiếu vào mặt. Nó cũng sẽ khiến tóc bạn bị cháy, vì vậy đừng thực sự làm vậy."
msgstr ""

#. LightBridge.STRINGS.BUILDINGS.PREFABS.LB_LIGHTBRIDGEEMITTER.EFFECT
msgctxt "LightBridge.STRINGS.BUILDINGS.PREFABS.LB_LIGHTBRIDGEEMITTER.EFFECT"
msgid "Phát ra một cây cầu ánh sáng bán thấm có chiều dài có thể định cấu hình.\n\nCây cầu dài hơn đòi hỏi lượng điện năng cao hơn"
msgstr ""

